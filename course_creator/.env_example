ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GOOGLE_API_KEY=...

OLLAMA_END_POINT=http://localhost:11434
OLLAMA_MODEL=qwen3.5:35b

ANTHROPIC_MODEL=claude-sonnet-4-6
# OPENAI_MODEL=gpt-4o
# GOOGLE_MODEL=gemini-1.5-pro

# Neo4j — dedicated container for course-creator RAG
# run.sh / run_in_background.sh will start this automatically with Docker.
# Override only if you want a different container or an external Neo4j instance.
NEO4J_URI=bolt://localhost:7688
NEO4J_USER=neo4j
NEO4J_PASSWORD=course_creator
NEO4J_CONTAINER=course_creator_neo4j
NEO4J_HTTP_PORT=7475
NEO4J_BOLT_PORT=7688
